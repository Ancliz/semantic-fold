{
  "name": "semantic-fold",
  "displayName": "Semantic Fold",
  "description": "Policy-driven code folding for VS Code",
  "version": "0.1.4-dev",
  "engines": {
    "vscode": "^1.111.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "semanticFold.collapse",
        "title": "Semantic Fold: Collapse"
      },
      {
        "command": "semanticFold.expand",
        "title": "Semantic Fold: Expand"
      },
      {
        "command": "semanticFold.toggle",
        "title": "Semantic Fold: Toggle"
      },
      {
        "command": "semanticFold.toggleAtCursor",
        "title": "Semantic Fold: Toggle Current Region"
      },
      {
        "command": "semanticFold.toggleDepth1",
        "title": "Semantic Fold: Toggle Level 1"
      },
      {
        "command": "semanticFold.toggleDepth2",
        "title": "Semantic Fold: Toggle Level 2"
      },
      {
        "command": "semanticFold.toggleDepth3",
        "title": "Semantic Fold: Toggle Level 3"
      },
      {
        "command": "semanticFold.toggleDepth4",
        "title": "Semantic Fold: Toggle Level 4"
      },
      {
        "command": "semanticFold.toggleDepth5",
        "title": "Semantic Fold: Toggle Level 5"
      },
      {
        "command": "semanticFold.toggleDepth6",
        "title": "Semantic Fold: Toggle Level 6"
      },
      {
        "command": "semanticFold.toggleDepth7",
        "title": "Semantic Fold: Toggle Level 7"
      },
      {
        "command": "semanticFold.toggleDepth8",
        "title": "Semantic Fold: Toggle Level 8"
      },
      {
        "command": "semanticFold.toggleDepth9",
        "title": "Semantic Fold: Toggle Level 9"
      },
      {
        "command": "semanticFold.toggleFunctions",
        "title": "Semantic Fold: Toggle Functions"
      },
      {
        "command": "semanticFold.toggleAll",
        "title": "Semantic Fold: Toggle All"
      },
      {
        "command": "semanticFold.runComposite",
        "title": "Semantic Fold: Run Composite"
      },
      {
        "command": "semanticFold.inspectRegions",
        "title": "Semantic Fold: Inspect Regions"
      },
      {
        "command": "semanticFold.toggleMethodsInClasses",
        "title": "Semantic Fold: Toggle Methods in Classes"
      },
      {
        "command": "semanticFold.toggleClassMembers",
        "title": "Semantic Fold: Toggle Class Members"
      },
      {
        "command": "semanticFold.toggleFunctionsInClasses",
        "title": "Semantic Fold: Toggle Functions in Classes"
      },
      {
        "command": "semanticFold.toggleTypes",
        "title": "Semantic Fold: Toggle Types"
      },
      {
        "command": "semanticFold.toggleVariables",
        "title": "Semantic Fold: Toggle Variables"
      },
      {
        "command": "semanticFold.toggleFunctionsInVariables",
        "title": "Semantic Fold: Toggle Functions in Variables"
      },
      {
        "command": "semanticFold.toggleImports",
        "title": "Semantic Fold: Toggle Imports"
      },
      {
        "command": "semanticFold.toggleComments",
        "title": "Semantic Fold: Toggle Comments"
      },
      {
        "command": "semanticFold.toggleReaderMode",
        "title": "Semantic Fold: Toggle Reader Mode"
      },
      {
        "command": "semanticFold.toggleApiOverview",
        "title": "Semantic Fold: Toggle API Overview"
      }
    ],
    "keybindings": [
      {
        "command": "semanticFold.toggleAtCursor",
        "key": "ctrl+shift+[",
        "when": "editorTextFocus"
      },
      {
        "command": "semanticFold.expand",
        "key": "ctrl+shift+]",
        "when": "editorTextFocus"
      },
      {
        "command": "semanticFold.toggleDepth1",
        "key": "alt+s alt+1",
        "when": "editorTextFocus"
      },
      {
        "command": "semanticFold.toggleDepth2",
        "key": "alt+s alt+2",
        "when": "editorTextFocus"
      },
      {
        "command": "semanticFold.toggleDepth3",
        "key": "alt+s alt+3",
        "when": "editorTextFocus"
      },
      {
        "command": "semanticFold.toggleDepth4",
        "key": "alt+s alt+4",
        "when": "editorTextFocus"
      },
      {
        "command": "semanticFold.toggleDepth5",
        "key": "alt+s alt+5",
        "when": "editorTextFocus"
      },
      {
        "command": "semanticFold.toggleDepth6",
        "key": "alt+s alt+6",
        "when": "editorTextFocus"
      },
      {
        "command": "semanticFold.toggleDepth7",
        "key": "alt+s alt+7",
        "when": "editorTextFocus"
      },
      {
        "command": "semanticFold.toggleDepth8",
        "key": "alt+s alt+8",
        "when": "editorTextFocus"
      },
      {
        "command": "semanticFold.toggleDepth9",
        "key": "alt+s alt+9",
        "when": "editorTextFocus"
      },
      {
        "command": "semanticFold.toggleFunctions",
        "key": "alt+s alt+m",
        "when": "editorTextFocus"
      },
      {
        "command": "semanticFold.toggleApiOverview",
        "key": "alt+s alt+a",
        "when": "editorTextFocus"
      },
      {
        "command": "semanticFold.toggleReaderMode",
        "key": "alt+s alt+r",
        "when": "editorTextFocus"
      },
      {
        "command": "semanticFold.toggleAll",
        "key": "alt+s alt+o",
        "when": "editorTextFocus"
      },
      {
        "command": "semanticFold.toggleComments",
        "key": "alt+s alt+/",
        "when": "editorTextFocus"
      }
    ],
    "configuration": {
      "title": "Semantic Fold",
      "properties": {
        "semanticFold.semanticRefinement.enabled": {
          "type": "boolean",
          "default": true,
          "scope": "resource",
          "description": "Enable semantic-token refinement for weak or ambiguous symbol classifications. When disabled, Semantic Fold uses only document symbols and folding ranges."
        },
        "semanticFold.presets.imports": {
          "type": "object",
          "default": {},
          "scope": "resource",
          "description": "Override the imports preset. Use enabled:false to disable the preset command for this scope.",
          "properties": {
            "enabled": {
              "type": "boolean",
              "description": "Enable or disable the imports preset command."
            },
            "filter": {
              "type": "object",
              "description": "Filter override for the imports preset. Supports the same fields as generic command filters."
            }
          }
        },
        "semanticFold.presets.comments": {
          "type": "object",
          "default": {},
          "scope": "resource",
          "description": "Override the comments preset. Use enabled:false to disable the preset command for this scope.",
          "properties": {
            "enabled": {
              "type": "boolean",
              "description": "Enable or disable the comments preset command."
            },
            "filter": {
              "type": "object",
              "description": "Filter override for the comments preset. Supports the same fields as generic command filters."
            }
          }
        },
        "semanticFold.presets.readerMode": {
          "type": "object",
          "default": {},
          "scope": "resource",
          "description": "Override the Reader Mode preset. Use enabled:false to disable the preset command for this scope.",
          "properties": {
            "enabled": {
              "type": "boolean",
              "description": "Enable or disable the Reader Mode preset command."
            },
            "filter": {
              "type": "object",
              "description": "Filter override for Reader Mode. Supports the same fields as generic command filters."
            }
          }
        },
        "semanticFold.presets.apiOverview": {
          "type": "object",
          "default": {},
          "scope": "resource",
          "description": "Override the API Overview preset. Use enabled:false to disable the preset command for this scope.",
          "properties": {
            "enabled": {
              "type": "boolean",
              "description": "Enable or disable the API Overview preset command."
            },
            "filters": {
              "type": "array",
              "description": "Composite filter overrides for API Overview. Each entry supports the same fields as generic command filters.",
              "items": {
                "type": "object"
              }
            }
          }
        },
        "semanticFold.presets.languageOverrides": {
          "type": "object",
          "default": {},
          "scope": "resource",
          "description": "Per-language preset overrides keyed by language id (for example typescript, javascript, python).",
          "additionalProperties": {
            "type": "object",
            "properties": {
              "imports": {
                "type": "object"
              },
              "comments": {
                "type": "object"
              },
              "readerMode": {
                "type": "object"
              },
              "apiOverview": {
                "type": "object"
              }
            }
          }
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "clean": "node -e \"require('fs').rmSync('out', { recursive: true, force: true })\"",
    "compile": "npm run clean && tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.116.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "typescript-eslint": "^8.56.1",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
}